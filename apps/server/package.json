{
  "name": "server",
  "type": "module",
  "main": "dist/main.mjs",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/main.ts --outfile server",
    "dev": "bun run --hot src/main.ts",
    "start": "bun run dist/main.mjs"
  },
  "dependencies": {
    "@hono/trpc-server": "^0.4.0",
    "@boilerplate/api": "workspace:*",
    "@boilerplate/auth": "workspace:*",
    "@boilerplate/db": "workspace:*",
    "@boilerplate/env": "workspace:*",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "evlog": "^2.13.0",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@boilerplate/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  },
  "trustedDependencies": [
    "supabase"
  ]
}
